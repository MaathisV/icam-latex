% Icam-Beamer
% Outer theme file (Headers, footers, numbering, sidebars)

\def\beamer@themeouter@true{true}
\def\beamer@themeouter@false{false}
\def\beamer@themeouter@vertical{vertical}
\def\beamer@themeouter@withsecplan{false}
\def\beamer@themeouter@navigation{false}

\DeclareOptionBeamer{navigation}{\def\beamer@themeouter@navigation{#1}}
\DeclareOptionBeamer{withsecplan}{\def\beamer@themeouter@withsecplan{#1}}
\ProcessOptionsBeamer

\mode<presentation>

% Header of a frame
\setbeamertemplate{frametitle}{
  \vspace*{-24pt} 
  \begin{tikzpicture}[remember picture, overlay]
     \node[anchor=north east, xshift=5pt, yshift=5pt] at (current page.north east) {
        \pgfuseimage{icam-logo}
     };
  \end{tikzpicture}

  \setlength{\fboxsep}{0pt} 
  
  % BREADCRUMBS
  \begin{minipage}{\textwidth}
    {\usebeamerfont{framesubtitle}\color{gray}\scriptsize
    \insertsection \ifx\insertsubsection\empty\else\ $\rightarrow$ \insertsubsection\fi}
  \end{minipage} \par

  \vspace*{-5pt}

  % TITLE
  \begin{minipage}{\textwidth}
    {\usebeamerfont{frametitle}\insertframetitle}
  \end{minipage} \par
  
  \vspace*{-8pt}

  \ifnum\inserttotalframenumber>0%
    \makeatletter
    \pgfmathsetmacro{\progresswidth}{\insertframenumber/\inserttotalframenumber}
    \color{icamorange}\rule{\progresswidth\textwidth}{1.5pt}
    \makeatother
  \fi
}

% Footer of a frame
\setbeamertemplate{footline}{
  \leavevmode
  \makebox[\paperwidth][l]{%
    % Column 1
    \colorbox{icamorange}{%
      \parbox[c][2.5ex][c]{0.33\paperwidth}{%
        \centering\color{white}\scriptsize ICAM
      }%
    }%
    % Column 2
    \colorbox{icamorange!60}{%
      \parbox[c][2.5ex][c]{0.34\paperwidth}{%
        \centering\color{white}\scriptsize \insertshorttitle
      }%
    }%
    % Column 3
    \colorbox{icamorange!30}{%
      \parbox[c][2.5ex][c]{0.33\paperwidth}{%
        \centering\color{black}\scriptsize % <--- Changed \raggedleft to \centering
      \insertframenumber/\inserttotalframenumber
    % Removed \hspace{0.5em} because centering handles the margins for you
      }%
    }%
  }%
}
% Make covered items semi-transparent instead of fully hidden
\beamertemplatetransparentcovered

% Hide navigation symbols if navigation=false
\ifx\beamer@themeouter@navigation\beamer@themeouter@false
  \setbeamertemplate{navigation symbols}{}
\fi

% Use vertical navigation symbols if navigation=vertical
\ifx\beamer@themeouter@navigation\beamer@themeouter@vertical
  \setbeamertemplate{navigation symbols}[vertical]
\fi

% Show a table of contents slide at each new section if withsecplan=true
\ifx\beamer@themeouter@withsecplan\beamer@themeouter@true
  \AtBeginSection[]{
    \begin{frame}<beamer>
      \frametitle{Plan}
      \tableofcontents[currentsection]
    \end{frame}
  }
\fi

% Return to processing all modes (not just presentation)
\mode<all>
