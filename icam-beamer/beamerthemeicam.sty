% Icam-Beamer
% Main theme file
\pgfdeclareimage[width=18mm]{icam-logo}{icam-common/icam_logo/logotype-seul-couleur-RVB.png}
\pgfdeclareimage[width=20mm]{icam-logo-text}{icam-common/icam_logo/logotype-baseline-couleur-RVB.png}
% Define beamer variables
\def\beamer@theme@true{true}
\def\beamer@theme@false{false}
\def\beamer@theme@withsecplan{false}
\def\beamer@theme@navigation{false}
\def\beamer@theme@icamrecherche{false}
\def\beamer@theme@pinkie{false}
\def\beamer@theme@rounded{true}
\def\beamer@theme@shadowed{false}

% Set posibles options
\DeclareOptionBeamer{navigation}{\def\beamer@theme@navigation{#1}}
\DeclareOptionBeamer{withsecplan}{\def\beamer@theme@withsecplan{#1}}
\DeclareOptionBeamer{pinkie}{\def\beamer@theme@pinkie{#1}}
\DeclareOptionBeamer{rounded}{\def\beamer@theme@rounded{#1}}
\DeclareOptionBeamer{shadowed}{\def\beamer@theme@shadowed{#1}}
\ProcessOptionsBeamer
\usepackage{tikz}
\mode<presentation>

\useoutertheme[navigation=\beamer@theme@navigation,withsecplan=\beamer@theme@withsecplan]{icam}
\useinnertheme[rounded=\beamer@theme@rounded,shadowed=\beamer@theme@shadowed]{icam}

\usecolortheme{icam} % the color theme defined in 'beamercolorthemeicam.sty'

\mode<all>

\def\hilite<#1>{%
  \temporal<#1>{\color{lightgray}}%
  {\color{icamrose}}%
  {\color{charcoal}}
}

\def\@email{}
\def\email#1{\def\@email{#1}}

% Semester
\def\@semester{}
\def\semester#1{\def\@semester{#1}}

% Icam Logo
\newcommand{\logoicam}[1]{\includegraphics[#1]{icam-common/icam_logo/logotype-baseline-couleur-RVB.png}}
\newcommand{\logoicamtext}[1]{\includegraphics[#1]{icam-common/icam_logo/logotype-seul-couleur-RVB.png}}

% Command to insert properly the semester
\newcommand{\insertsemester}{
  \ifx\@semester\@empty
    \relax
  \else
    \@semester\\
  \fi
}

% Title page of the beamer
\setbeamertemplate{title page}{
  \begin{center}
    {\usebeamerfont{title}\usebeamercolor[fg]{title}\Large\inserttitle}\par
    \ifx\insertsubtitle\@empty\else
    \vspace{.3cm}
      {\usebeamerfont{subtitle}\usebeamercolor[fg]{subtitle}\insertsubtitle}\par
    \fi
    
    \vfill % Pushes Institute/Logo to the bottom
    
    % 3. THE LOGO ROW (ICAM + Others)
    \begin{minipage}{\textwidth}
      \centering
      \includegraphics[width=2.5cm]{icam-common/icam_logo/logotype-baseline-couleur-RVB.png}
      \ifx\inserttitlegraphic\@empty
      \else
        \quad\quad
        \inserttitlegraphic
      \fi
    \end{minipage}\par
    
    \vspace{0.3cm}
    
    {\usebeamerfont{institute}\insertinstitute}
    \vfill
    {\usebeamerfont{author}\usebeamercolor[fg]{author}\insertauthor}
    \quad--\quad
    {\usebeamerfont{date}\usebeamercolor[fg]{date}\insertdate}
  \end{center}
}

% End page of the beamer
\newcommand{\icamthankspage}[1][Thanks]{
  \raisebox{-11pt}[0pt]{\logoicam{width=3cm}}
  \usebeamercolor{inverted structure}
  \begin{center}
    \vfill
    \Huge{#1}\\
    \vspace{.5cm}
    \usebeamercolor[fg]{structure}
    \large{\textbf{\insertauthor}}\\
    \usebeamercolor[fg]{inverted structure}
    \ifx\@email\@empty
      \relax
    \else
      \vspace{.3cm}
      \large{\@email}\\
    \fi
    \vspace{.5cm}
    \begin{footnotesize}
      \inserttitle
      \ifx\insertsubtitle\@empty
        \relax
      \else
        ~---~\insertsubtitle
      \fi\\
      \vspace{.5cm}
      \insertsemester
      \insertdate
    \end{footnotesize}
    \vfill
  \end{center}
}
